{
    "base_folder": ".",
    "dataset_path": "./data/adni/CT_Vol_graphs_complete_features_filtered_negative.pt",
    "cross_val_pkl": "./data/adni/splits/reporting_cv_splits.pkl",
    "run_dir": null,
    "dataset": "adni",
    "epochs": 120,
    "lr": 5e-05,
    "seed": 42,
    "batch_size": 64,
    "dropout": 0.4,
    "include_adjacency_transformer": true,
    "fusion": "concat",
    "task": "diagnosis",
    "include_cortex_mlp": true,
    "cortex_mlp_dropout": 0.4,
    "cortex_mlp_hidden_dim": 64,
    "cortex_mlp_use_residual": true,
    "cortex_mlp_activation": "leakyrelu",
    "cortex_mlp_use_layernorm": false,
    "cortex_mlp_num_layers": 1,
    "cortex_mlp_hidden_dims": null,
    "cortex_mlp_width_mode": "constant",
    "adjacency_transformer_dropout": 0.4,
    "adjacency_transformer_hidden_dim": 256,
    "adjacency_transformer_num_layers": 2,
    "adjacency_transformer_num_heads": 1,
    "adjacency_transformer_cnn_input_add_flattened_node_features": true,
    "adjacency_transformer_add_output_skip": true,
    "pos_encoding_type": "learnable",
    "lpe_dim": 8,
    "use_class_weights": false,
    "balanced_batches": false,
    "weight_decay": 0.05,
    "node_feature_set": "ct_vol_sa_mc_sd",
    "excluded_node_features": "std_min_max",
    "cog_feature_set": "all",
    "early_stopping": true,
    "es_monitor": "es_f1_weighted",
    "es_patience": 20,
    "es_min_delta": 0.0025,
    "es_mode": "max"
}