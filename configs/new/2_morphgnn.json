{
    "base_folder": ".",
    "dataset_path": "./data/adni/CT_Vol_graphs_complete_features_filtered_negative.pt",
    "cross_val_pkl": "./data/adni/splits/reporting_cv_splits.pkl",
    "run_dir": null,
    "dataset": "adni",
    "epochs": 40,
    "lr": 5e-05,
    "seed": 42,
    "batch_size": 64,
    "dropout": 0.2,
    "fusion": "concat",
    "task": "diagnosis",
    "include_adjacency_gnn": true,
    "adjacency_gnn_dropout": 0.2,
    "adjacency_gnn_hidden_dim": 64,
    "edge_threshold": 1.0,
    "adjacency_gnn_num_layers": 1,
    "adjacency_gnn_layer": "gcn",
    "add_adj_row_as_node_feature": false,
    "separate_adj_features_instead_of_concat": false,
    "add_weighted_degree_as_node_feature": false,
    "adjacency_gnn_use_pre_mlp": true,
    "adjacency_gnn_cnn_input_add_flattened_node_features": true,
    "adjacency_gnn_add_output_skip": true,
    "adjacency_gnn_layer_connectivity": "skipsum",
    "adjacency_gnn_norm_type": "layernorm",
    "adjacency_gnn_readout": "cnn",
    "adjacency_gnn_graph_pool": "mean_max",
    "use_class_weights": false,
    "balanced_batches": false,
    "weight_decay": 0.05,
    "node_feature_set": "ct_vol_sa_mc_sd",
    "excluded_node_features": "std_min_max",
    "cog_feature_set": "all",
    "early_stopping": true,
    "es_monitor": "es_f1_weighted",
    "es_patience": 10,
    "es_min_delta": 0.0025,
    "es_mode": "max"
}